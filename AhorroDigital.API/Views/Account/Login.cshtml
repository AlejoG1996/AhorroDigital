@model AhorroDigital.API.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}
@{
    Layout = null;
}
<meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0" />
<meta charset="utf-8" />
<link rel="icon" type="image/x-icon" href="/images/ahorrar-dinero.ico" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/LoginStyle.css" />
<script src="https://use.fontawesome.com/releases/v6.1.0/js/all.js" crossorigin="anonymous"></script>

<body onload="myFunction()">
    <div class="container">
        <section id="formHolder">

            <div class="row">

                <!-- Brand Box -->
                <div class="col-sm-6 brand">
                    <a class="navbar-brand" href="#page-top"><img class="logo-ini" src="/images/navbar-logo.png" alt="..." /></a>

                    <div class="heading">
                        <h2>Ahorro Digital.</h2>
                        <p>Ahorrar no es solo guardar, sino saber gastar</p>
                    </div>

                    <div class="success-msg">

                    </div>
                </div>


                <!-- Form Box -->
                <div class="col-sm-6 form fmr">

                    <!-- Login Form -->
                    <div class="login form-peice switched">
                        <form class="signup-form" action="#" method="post">

                            <div class="form-group">
                                <label for="name">Full Name</label>
                                <input type="text" name="username" id="name" class="name">
                                <span class="error"></span>
                            </div>

                            <div class="form-group">
                                <label for="email">Email Adderss</label>
                                <input type="email" name="emailAdress" id="email" class="email">
                                <span class="error"></span>
                            </div>

                            <div class="form-group">
                                <label for="phone">Phone Number - <small>Optional</small></label>
                                <input type="text" name="phone" id="phone">
                            </div>

                            <div class="form-group">
                                <label for="password">Password</label>
                                <input type="password" name="password" id="password" class="pass">
                                <span class="error"></span>
                            </div>

                            <div class="form-group">
                                <label for="passwordCon">Confirm Password</label>
                                <input type="password" name="passwordCon" id="passwordCon" class="passConfirm">
                                <span class="error"></span>
                            </div>

                            <div class="CTA">
                                <input type="submit" value="Signup Now">
                                <br />
                                <a href="#" class="switch">I have an account</a>
                            </div>
                        </form>

                    </div><!-- End Login Form -->
                    <!-- Signup Form -->

                    <div class="signup form-peice ">
                        <form method="post" id="myform">
                            <h2 class="section-heading text-uppercase text-center text_color">Inicio de Sesión</h2>
                            <br />
                            <div asp-validation-summary="ModelOnly" class="errorinicio" id="error"></div>

                            <script>
                                var txtinfo = document.getElementById("#txtcorrero");
                                function myFunction() {
                                    if (txtinfo != '') {
                                        $("#txtcorrero").val('');
                                    }
                                }
                            </script>
                            <div class="form-group">
                                <label asp-for="Username"></label>
                                <input asp-for="Username" class="act" id="txtcorrero" />
                                <span asp-validation-for="Username" class="text-warning"></span>
                            </div>
                            <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>

                            <div class="form-group">
                                <label asp-for="Password"></label>
                                <input asp-for="Password" type="password" class="" />
                                <span asp-validation-for="Password" class="text-warning"></span>
                            </div>

                            <div class="form-group">
                                <div class="form-check">
                                    <p class="">
                                        <input asp-for="RememberMe" type="checkbox" class="form-check-input" /><a class="check">Recordar datos</a>

                                    </p>

                                    @*<label asp-for="RememberMe" class="form-check-label"></label>*@
                                </div>
                            </div>

                            <div class="form-group">
                                <button type="submit" value="Iniciar Sesión" class="btn btn-primary"><span>Iniciar Sesión</span><span><i class="fas fa-sign-in-alt"></i></span></button>

                            </div>
                            <div class="form-group">
                                <a asp-action="Register" class="btn btn-secondary switch"><span>Nuevo Usuario</span><span><i class="fas fa-user-plus"></i></span></a>
                                <hr />
                                <a asp-action="RecoverPassword" class="btn btn-link">¿Olvidaste tu contraseña?</a>
                            </div>
                        </form>
                    </div><!-- End Signup Form -->


                </div>
            </div>

        </section>


        <footer>
            <p>
            </p>
        </footer>
        <script>
            $(document).ready(function () {
                $(".act").click();
            });
        </script>


    </div>
    <script src="https://cpwebassets.codepen.io/assets/common/stopExecutionOnTimeout-1b93190375e9ccc259df3a57c1abc0e64599724ae30d7ea4c6877eb615f89387.js"></script>

    <script src='https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.0/jquery.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script src="~/js/Login.js"></script>

</body>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}